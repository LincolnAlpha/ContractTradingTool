PORT=3000

# 代理白名单域名（逗号分隔）
# 例如：api.binance.com,fapi.binance.com,api.coingecko.com
PROXY_ALLOWED_DOMAINS=

# 新闻源（JSON 字符串）
# 例如：[{"url":"https://www.coindesk.com/arc/outboundfeeds/rss/","name":"CoinDesk"},{"url":"https://cointelegraph.com/rss","name":"Cointelegraph"}]
NEWS_RSS_SOURCES=

# 直播源配置
LIVE_PAGE_URL=
LIVE_API_URL=
LIVE_REFERER=
LIVE_ORIGIN=
